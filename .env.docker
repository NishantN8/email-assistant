# ─────────────────────────────────────────────────────────────────
# AI Email Copilot — Docker Environment Template
# Copy to .env before running: cp .env.docker .env
# ─────────────────────────────────────────────────────────────────

# ── PostgreSQL ────────────────────────────────────────────────────
POSTGRES_USER=copilot
POSTGRES_PASSWORD=change_me_in_production
POSTGRES_DB=copilot_db

# ── Redis ─────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379

# ── API Server ────────────────────────────────────────────────────
SESSION_SECRET=change_me_to_a_long_random_string_min_32_chars

# ── Google OAuth ──────────────────────────────────────────────────
GOOGLE_CLIENT_ID=315081352824-si7lehcb4tqic9m96c9mavsmuo479gds.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret_here
GOOGLE_REDIRECT_URI=http://localhost:8080/api/auth/callback

# ── OpenAI (cloud fallback) ───────────────────────────────────────
# Leave blank to disable cloud AI (local-only mode)
OPENAI_API_KEY=sk-...

# ── vLLM (GPU primary — comment out if using Ollama only) ─────────
# Which model to serve — needs HF_TOKEN if gated
VLLM_MODEL=mistralai/Mistral-7B-Instruct-v0.3
VLLM_GPU_MEMORY_UTILIZATION=0.90
VLLM_MAX_MODEL_LEN=8192
VLLM_TENSOR_PARALLEL=1

# HuggingFace token (required for gated models like Llama 3)
HF_TOKEN=hf_...

# ── Ollama model pull list ─────────────────────────────────────────
# Space-separated list of models to pull on startup
OLLAMA_MODELS=llama3:8b mistral:7b

# ── Worker ────────────────────────────────────────────────────────
WORKER_CONCURRENCY_LOCAL=4
WORKER_CONCURRENCY_CLOUD=8

# ── Frontend ──────────────────────────────────────────────────────
VITE_API_URL=http://localhost:8080

# ── GPU (set automatically by docker-compose.gpu.yml) ────────────
# CUDA_VISIBLE_DEVICES=0
# GPU_AVAILABLE=true
