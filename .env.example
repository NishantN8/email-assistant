# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/email_copilot

# Sessions (generate with: openssl rand -hex 32)
SESSION_SECRET=your-random-secret-minimum-32-chars

# Google OAuth — https://console.cloud.google.com/
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret
GOOGLE_REDIRECT_URI=http://localhost:3001/api/auth/google/callback

# Ollama (optional — defaults to localhost)
# OLLAMA_HOST=http://localhost:11434
# OLLAMA_NUM_GPU_LAYERS=35
# OLLAMA_GPU_MEMORY_FRACTION=0.90
# CUDA_VISIBLE_DEVICES=0

# Cloud AI Fallback Providers (add as many as you want; missing keys are skipped)
# Priority order: Groq → Gemini → Mistral → OpenRouter → OpenAI
GROQ_API_KEY=
GOOGLE_AI_API_KEY=
MISTRAL_API_KEY=
OPENROUTER_API_KEY=
OPENAI_API_KEY=
